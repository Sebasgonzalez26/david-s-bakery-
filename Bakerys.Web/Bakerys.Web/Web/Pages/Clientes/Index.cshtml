@page
@model Web.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
    ViewData["Page"]  = "Clientes";
}

<div class="db-page-header">
    <div>
        <h1 class="db-page-title">Clientes</h1>
        <p class="db-page-sub">Gestioná los clientes registrados en el sistema</p>
    </div>
    <a asp-page="./Agregar" class="db-btn db-btn-primary">
        <i class="bi bi-person-plus"></i> Nuevo Cliente
    </a>
</div>

<!-- Búsqueda -->
<div class="db-card" style="margin-bottom: 20px;">
    <div class="db-card-body" style="padding: 16px 24px;">
        <form method="get">
            <div style="display: flex; gap: 10px; align-items: center;">
                <div style="position: relative; flex: 1;">
                    <i class="bi bi-search" style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:13px;"></i>
                    <input type="text" name="Busqueda" value="@Model.Busqueda"
                           class="db-form-control" style="padding-left: 36px;"
                           placeholder="Buscar por nombre o teléfono..." />
                </div>
                <button type="submit" class="db-btn db-btn-primary">Buscar</button>
                @if (!string.IsNullOrEmpty(Model.Busqueda))
                {
                    <a asp-page="./Index" class="db-btn db-btn-outline">Limpiar</a>
                }
            </div>
        </form>
    </div>
</div>

<!-- Tabla -->
<div class="db-card">
    <div class="db-card-header">
        <h2 class="db-card-title"><i class="bi bi-people"></i> Listado de Clientes</h2>
        <span style="font-size:12px; color:var(--text-muted);">@Model.Clientes.Count registro(s)</span>
    </div>
    @if (Model.Clientes.Any())
    {
        <table class="db-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Teléfono</th>
                    <th>Email</th>
                    <th>Estado</th>
                    <th>Registro</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model.Clientes)
                {
                    <tr>
                        <td style="color:var(--text-muted); font-size:12px;">@cliente.Id</td>
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <div style="width:32px; height:32px; border-radius:50%; background:var(--gold-light); display:flex; align-items:center; justify-content:center; font-family:var(--font-heading); font-weight:600; color:var(--brown-mid); font-size:13px; flex-shrink:0;">
                                    @cliente.Nombre.Substring(0, 1).ToUpper()
                                </div>
                                <span style="font-weight:500;">@cliente.Nombre</span>
                            </div>
                        </td>
                        <td>@cliente.Telefono</td>
                        <td style="color:var(--text-muted);">@(cliente.Email ?? "—")</td>
                        <td>
                            @if (cliente.Activo)
                            {
                                <span class="db-badge db-badge-green"><i class="bi bi-circle-fill" style="font-size:6px;"></i> Activo</span>
                            }
                            else
                            {
                                <span class="db-badge db-badge-red"><i class="bi bi-circle-fill" style="font-size:6px;"></i> Inactivo</span>
                            }
                        </td>
                        <td style="font-size:12.5px; color:var(--text-muted);">
                            @cliente.FechaRegistro.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            <div style="display:flex; gap:6px; justify-content:flex-end;">
                                <a asp-page="./Editar" asp-route-id="@cliente.Id"
                                   class="db-btn db-btn-outline db-btn-sm">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                @if (cliente.Activo)
                                {
                                    <form method="post" asp-page-handler="Desactivar"
                                          onsubmit="return confirm('¿Desactivar a @cliente.Nombre?')">
                                        <input type="hidden" name="id" value="@cliente.Id" />
                                        <button type="submit" class="db-btn db-btn-danger db-btn-sm">
                                            <i class="bi bi-person-dash"></i> Desactivar
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="db-empty">
            <i class="bi bi-people"></i>
            <p>@(string.IsNullOrEmpty(Model.Busqueda) ? "No hay clientes registrados aún" : "No se encontraron clientes con esa búsqueda")</p>
        </div>
    }
</div>
