<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Davi's Bakery</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="db-body">

    <!-- Sidebar -->
    <aside class="db-sidebar">
        <div class="db-sidebar-brand">
            <div class="db-brand-icon">DB</div>
            <div class="db-brand-text">
                <span class="db-brand-name">Davi's Bakery</span>
                <span class="db-brand-sub">Encanto Pastelero</span>
            </div>
        </div>

        <nav class="db-nav">
            <p class="db-nav-label">Principal</p>
            <a class="db-nav-link @(ViewData["Page"]?.ToString() == "Dashboard" ? "active" : "")" asp-page="/Bakery/Index">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>

            <p class="db-nav-label">Gestión</p>
            <a class="db-nav-link @(ViewData["Page"]?.ToString() == "Clientes" ? "active" : "")" asp-page="/Clientes/Index">
                <i class="bi bi-people"></i> Clientes
            </a>
            <a class="db-nav-link @(ViewData["Page"]?.ToString() == "Pedidos" ? "active" : "")" asp-page="/Pedidos/Index">
                <i class="bi bi-box-seam"></i> Pedidos
            </a>
            <a class="db-nav-link @(ViewData["Page"]?.ToString() == "Pagos" ? "active" : "")" asp-page="/Pagos/Index">
                <i class="bi bi-credit-card"></i> Pagos
            </a>

            <p class="db-nav-label">Operaciones</p>
            <a class="db-nav-link @(ViewData["Page"]?.ToString() == "Inventario" ? "active" : "")" asp-page="/Inventario/Index">
                <i class="bi bi-archive"></i> Inventario
            </a>
            <a class="db-nav-link @(ViewData["Page"]?.ToString() == "Finanzas" ? "active" : "")" asp-page="/Finanzas/Index">
                <i class="bi bi-bar-chart-line"></i> Finanzas
            </a>
        </nav>

        <div class="db-sidebar-footer">
            <i class="bi bi-c-circle"></i> 2026 Davi's Bakery
        </div>
    </aside>

    <!-- Main -->
    <div class="db-main">
        <header class="db-topbar">
            <h1 class="db-topbar-title">@ViewData["Title"]</h1>
            <div class="db-topbar-right">
                <span class="db-topbar-date">
                    <i class="bi bi-calendar3"></i>
                    @DateTime.Now.ToString("dd 'de' MMMM, yyyy", new System.Globalization.CultureInfo("es-CR"))
                </span>
            </div>
        </header>

        <main class="db-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
