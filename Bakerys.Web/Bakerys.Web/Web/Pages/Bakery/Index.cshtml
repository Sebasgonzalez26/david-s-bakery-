@page
@model Web.Pages.Bakery.IndexModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Page"]  = "Dashboard";
    var hora = DateTime.Now.Hour;
    var saludo = hora < 12 ? "Buenos días" : hora < 19 ? "Buenas tardes" : "Buenas noches";
    var mes = DateTime.Now.ToString("MMMM yyyy", new System.Globalization.CultureInfo("es-CR"));
    mes = char.ToUpper(mes[0]) + mes.Substring(1);
}

<!-- Hero Banner -->
<div class="db-hero" style="margin-bottom:24px;">
    <div class="db-hero-content">
        <div>
            <p class="db-hero-greeting">✦ Panel Administrativo</p>
            <h1 class="db-hero-title">@saludo,<br>Davi's Bakery</h1>
            <p class="db-hero-sub">@mes · @DateTime.Now.ToString("dddd", new System.Globalization.CultureInfo("es-CR"))</p>
        </div>
        <div class="db-hero-badge">
            @if (Model.Resumen != null)
            {
                <div class="db-hero-stat">
                    <div class="db-hero-stat-label">Ingresos del mes</div>
                    <div class="db-hero-stat-value">₡@Model.Resumen.TotalIngresos.ToString("N0")</div>
                    <div class="db-hero-stat-sub">Balance: ₡@Model.Resumen.BalanceNeto.ToString("N0")</div>
                </div>
            }
        </div>
    </div>
</div>

<!-- KPIs -->
<div class="db-kpi-grid">
    <div class="db-kpi-card kpi-brown">
        <div class="db-kpi-header">
            <span class="db-kpi-label">Clientes</span>
            <div class="db-kpi-icon"><i class="bi bi-people-fill"></i></div>
        </div>
        <div class="db-kpi-value">@Model.TotalClientes</div>
        <div class="db-kpi-sub">
            <i class="bi bi-circle-fill" style="font-size:6px; color:var(--green-500);"></i>
            registrados en el sistema
        </div>
    </div>

    <div class="db-kpi-card kpi-gold">
        <div class="db-kpi-header">
            <span class="db-kpi-label">Pedidos activos</span>
            <div class="db-kpi-icon"><i class="bi bi-box-seam-fill"></i></div>
        </div>
        <div class="db-kpi-value">@Model.PedidosActivos</div>
        <div class="db-kpi-sub">
            @if (Model.PedidosPendientes > 0)
            {
                <span class="db-kpi-trend-down"><i class="bi bi-clock"></i> @Model.PedidosPendientes pendiente(s)</span>
            }
            else
            {
                <span class="db-kpi-trend-up"><i class="bi bi-check-circle"></i> todos atendidos</span>
            }
        </div>
    </div>

    <div class="db-kpi-card kpi-green">
        <div class="db-kpi-header">
            <span class="db-kpi-label">Gastos del mes</span>
            <div class="db-kpi-icon"><i class="bi bi-receipt"></i></div>
        </div>
        <div class="db-kpi-value" style="font-size:30px;">
            @(Model.Resumen != null ? "₡" + Model.Resumen.TotalGastos.ToString("N0") : "—")
        </div>
        <div class="db-kpi-sub">registrados este mes</div>
    </div>

    <div class="db-kpi-card kpi-red">
        <div class="db-kpi-header">
            <span class="db-kpi-label">Stock bajo</span>
            <div class="db-kpi-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
        </div>
        <div class="db-kpi-value">@Model.ProductosStockBajo</div>
        <div class="db-kpi-sub">
            @if (Model.ProductosStockBajo == 0)
            {
                <span class="db-kpi-trend-up"><i class="bi bi-check-circle"></i> inventario en orden</span>
            }
            else
            {
                <span class="db-kpi-trend-down"><i class="bi bi-arrow-up"></i> requieren atención</span>
            }
        </div>
    </div>
</div>

<!-- Segunda fila -->
<div class="db-grid-6-4">

    <!-- Pedidos recientes -->
    <div class="db-card">
        <div class="db-card-header">
            <h2 class="db-card-title">
                <i class="bi bi-clock-history"></i> Pedidos Recientes
            </h2>
            <div style="display:flex; align-items:center; gap:8px;">
                <span class="db-num-pill">@Model.Pedidos.Count total</span>
                <a asp-page="/Pedidos/Index" class="db-btn db-btn-outline db-btn-xs">Ver todos <i class="bi bi-arrow-right"></i></a>
            </div>
        </div>
        @if (Model.Pedidos.Any())
        {
            <table class="db-table">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Entrega</th>
                        <th>Estado</th>
                        <th>Saldo pend.</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Pedidos.OrderByDescending(x => x.FechaCreacion).Take(7))
                    {
                        var badge = p.Estado switch {
                            "Pendiente"  => "db-badge-amber",
                            "En Proceso" => "db-badge-blue",
                            "Listo"      => "db-badge-gold",
                            "Entregado"  => "db-badge-green",
                            "Cancelado"  => "db-badge-red",
                            _            => "db-badge-brown"
                        };
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:10px;">
                                    <div class="db-avatar">@p.Cliente.Substring(0,1).ToUpper()</div>
                                    <div>
                                        <div style="font-weight:500; font-size:13px;">@p.Cliente</div>
                                        <div style="font-size:11px; color:var(--text-400);">@p.Telefono</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="font-size:12.5px;">@p.FechaEntrega.ToString("dd MMM")</div>
                                <div style="font-size:11px; color:var(--text-400);">@p.FechaEntrega.ToString("yyyy")</div>
                            </td>
                            <td><span class="db-badge @badge">@p.Estado</span></td>
                            <td style="font-size:12.5px; color:@(p.SaldoPendiente > 0 ? "var(--red-500)" : "var(--green-500)");">
                                ₡@p.SaldoPendiente.ToString("N0")
                            </td>
                            <td style="font-weight:600; font-size:13px;">₡@p.MontoTotal.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="db-empty">
                <i class="bi bi-box-seam"></i>
                <p>No hay pedidos registrados aún</p>
            </div>
        }
    </div>

    <!-- Panel lateral -->
    <div>

        <!-- Accesos rápidos -->
        <div class="db-card" style="margin-bottom:16px;">
            <div class="db-card-header">
                <h2 class="db-card-title"><i class="bi bi-lightning-charge"></i> Accesos Rápidos</h2>
            </div>
            <div class="db-card-body" style="display:flex; flex-direction:column; gap:8px;">
                <a asp-page="/Clientes/Agregar" class="db-quick-card">
                    <div class="db-quick-card-icon"><i class="bi bi-person-plus"></i></div>
                    <div class="db-quick-card-text">
                        <strong>Nuevo Cliente</strong>
                        <span>Registrar cliente nuevo</span>
                    </div>
                    <i class="bi bi-chevron-right" style="color:var(--text-300); margin-left:auto; font-size:12px;"></i>
                </a>
                <a asp-page="/Pedidos/Agregar" class="db-quick-card">
                    <div class="db-quick-card-icon"><i class="bi bi-plus-circle"></i></div>
                    <div class="db-quick-card-text">
                        <strong>Nuevo Pedido</strong>
                        <span>Crear un pedido para cliente</span>
                    </div>
                    <i class="bi bi-chevron-right" style="color:var(--text-300); margin-left:auto; font-size:12px;"></i>
                </a>
                <a asp-page="/Inventario/Index" class="db-quick-card">
                    <div class="db-quick-card-icon"><i class="bi bi-archive"></i></div>
                    <div class="db-quick-card-text">
                        <strong>Inventario</strong>
                        <span>Ver y registrar movimientos</span>
                    </div>
                    <i class="bi bi-chevron-right" style="color:var(--text-300); margin-left:auto; font-size:12px;"></i>
                </a>
                <a asp-page="/Finanzas/Index" class="db-quick-card">
                    <div class="db-quick-card-icon"><i class="bi bi-bar-chart-line"></i></div>
                    <div class="db-quick-card-text">
                        <strong>Finanzas</strong>
                        <span>Ingresos y gastos del período</span>
                    </div>
                    <i class="bi bi-chevron-right" style="color:var(--text-300); margin-left:auto; font-size:12px;"></i>
                </a>
            </div>
        </div>

        <!-- Stock bajo -->
        <div class="db-card">
            <div class="db-card-header">
                <h2 class="db-card-title"><i class="bi bi-exclamation-triangle"></i> Alertas de Stock</h2>
                @if (Model.StockBajo.Any())
                {
                    <span class="db-badge db-badge-red">@Model.StockBajo.Count alerta(s)</span>
                }
            </div>
            <div class="db-card-body">
                @if (Model.StockBajo.Any())
                {
                    @foreach (var prod in Model.StockBajo.Take(4))
                    {
                        var pct = prod.StockMinimo > 0
                            ? (int)Math.Min(prod.StockActual / prod.StockMinimo * 100, 100) : 0;
                        <div style="margin-bottom:16px;">
                            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:3px;">
                                <span style="font-size:13px; font-weight:500; color:var(--text-900);">@prod.Nombre</span>
                                <span style="font-size:11.5px; font-weight:600; color:var(--red-500);">
                                    @prod.StockActual @prod.UnidadMedida
                                </span>
                            </div>
                            <div style="font-size:11px; color:var(--text-400); margin-bottom:5px;">
                                Mínimo requerido: @prod.StockMinimo @prod.UnidadMedida
                            </div>
                            <div class="db-stock-bar">
                                <div class="db-stock-bar-fill low" style="width:@pct%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="db-alert db-alert-success" style="margin:0;">
                        <i class="bi bi-check-circle-fill"></i>
                        Todo el inventario está en orden
                    </div>
                }
            </div>
        </div>

    </div>
</div>
